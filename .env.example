# ============================================================
# Autonomous AI Company — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real API key:
#   cp .env.example .env

# Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Which Claude model to use
# Options: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6
